#3.1
SELECT *
FROM STUDENTS;
#3.2
SELECT NAME,GRADE
FROM STUDENTS;
#3.3
SELECT NAME, GRADE
FROM STUDENTS
WHERE GRADE > 90;
#3.4
SELECT NAME
FROM STUDENTS
WHERE NAME LIKE 'M%';
#3.5
SELECT
avg(GRADE) as avg_grade,
max(GRADE) as max_grade,
min(GRADE) as min_grade
FROM STUDENTS;
#3.6
SELECT NAME,GRADE
FROM STUDENTS
WHERE GRADE > (SELECT avg(GRADE) FROM STUDENTS);

  
